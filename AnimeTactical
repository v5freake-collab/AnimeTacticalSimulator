            while NebuState.Nebublox_Running do
                pcall(function()
                    local activeRaidWorld = nil
                    for worldName, isEnabled in pairs(NebuState.AutoDungeonEnabled) do
                        if isEnabled then 
                            activeRaidWorld = worldName
                            break
                        end
                    end

                    if activeRaidWorld then
                        if player:FindFirstChild("OnRaids") then
                            -- Inside raid — auto-farm handles enemies via context-aware targeting
                        else
                            pcall(function()
                                local raidsLobbies = ReplicatedStorage.Remotes.Gameplays.RaidsLobbies
                                local raidsEvent = ReplicatedStorage.Remotes.Systems.RaidsEvent
                                local parties = ReplicatedStorage:FindFirstChild("Shared") and ReplicatedStorage.Shared:FindFirstChild("Parties")
                                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                if not root then return end

                                -- Step 1: Find existing party folder
                                local partyFolder = nil
                                if parties then
                                    for _, folder in ipairs(parties:GetChildren()) do
                                        if folder:FindFirstChild(player.Name .. " _Owners") then
                                            partyFolder = folder
                                            break
                                        end
                                    end
                                end

                                -- Step 2: Touch Raids_Entering part to create party
                                if not partyFolder then
                                    local raidsEntering = workspace:FindFirstChild("Raids_Entering")
                                    if raidsEntering then
                                        for _, entryModel in ipairs(raidsEntering:GetChildren()) do
                                            if entryModel:IsA("Model") then
                                                local touchParts = {}
                                                if entryModel:FindFirstChild("Centers") then
                                                    for _, p in ipairs(entryModel.Centers:GetDescendants()) do
                                                        if p:IsA("BasePart") then table.insert(touchParts, p) end
                                                    end
                                                end
                                                if #touchParts == 0 then
                                                    for _, p in ipairs(entryModel:GetDescendants()) do
                                                        if p:IsA("BasePart") then table.insert(touchParts, p) end
                                                    end
                                                end

                                                for _, touchPart in ipairs(touchParts) do
                                                    root.CFrame = touchPart.CFrame * CFrame.new(0, 0, 0)
                                                    task.wait(0.2)
                                                    if firetouchinterest then
                                                        firetouchinterest(root, touchPart, 0)
                                                        task.wait(0.3)
                                                        firetouchinterest(root, touchPart, 1)
                                                    end
                                                    task.wait(0.5)
                                                    if parties then
                                                        for _, folder in ipairs(parties:GetChildren()) do
                                                            if folder:FindFirstChild(player.Name .. " _Owners") then
                                                                partyFolder = folder
                                                                break
                                                            end
                                                        end
                                                    end
                                                    if partyFolder then break end
                                                end
                                                if partyFolder then break end
                                            elseif entryModel:IsA("BasePart") then
                                                root.CFrame = entryModel.CFrame
                                                task.wait(0.2)
                                                if firetouchinterest then
                                                    firetouchinterest(root, entryModel, 0)
                                                    task.wait(0.3)
                                                    firetouchinterest(root, entryModel, 1)
                                                end
                                                task.wait(0.5)
                                                if parties then
                                                    for _, folder in ipairs(parties:GetChildren()) do
                                                        if folder:FindFirstChild(player.Name .. " _Owners") then
                                                            partyFolder = folder
                                                            break
                                                        end
                                                    end
                                                end
                                                if partyFolder then break end
                                            end
                                        end
                                    end
                                end

                                -- Step 3: Set world + difficulty, start raid
                                if partyFolder then
                                    local diffLevel = NebuState.AutoDungeonLevels[activeRaidWorld] or "Easy"
                                    task.wait(0.5)
                                    raidsLobbies:FireServer(partyFolder, "Worlds_" .. activeRaidWorld)
                                    task.wait(0.5)
                                    raidsLobbies:FireServer(partyFolder, "Difficulty_" .. diffLevel)
                                    task.wait(0.5)
                                    raidsEvent:FireServer(activeRaidWorld, diffLevel)
                                    raidsLobbies:FireServer(partyFolder, nil, true)
                                end
                            end)
                        end
                    end
                end)
                task.wait(5)
            end
        end)

        -- ═══════════════════════════════════════════

        -- ═══════════════════════════════════════════
        -- UPGRADED: EVENT-DRIVEN SMART MULTITASK
        -- ═══════════════════════════════════════════
        local function TeleportToLobby()
            pcall(function()
                local Packets = require(game:GetService("ReplicatedStorage").Modules.Packets.Managements)
                local tpPacket = Packets:GetPacket("Teleporters", "Loaders")
                if tpPacket and tpPacket.send then tpPacket.send("Lobby") end
                
                -- ByteNet Teleport
                pcall(function()
                    if buffer and buffer.fromstring then
                        local args = { buffer.fromstring("\005\005\000Lobby\004\005\000Lobby") }
                        game:GetService("ReplicatedStorage"):WaitForChild("ByteNetReliable"):FireServer(unpack(args))
                    end
                end)

                -- Physical Fallback
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    local lobbyArea = workspace:FindFirstChild("Maps") and workspace.Maps:FindFirstChild("Lobby")
                    if lobbyArea then
                        local spawnPart = lobbyArea:FindFirstChild("SpawnLocation") or lobbyArea:FindFirstChildWhichIsA("SpawnLocation")
                        if spawnPart then
                            root.CFrame = spawnPart.CFrame * CFrame.new(0, 5, 0)
                        end
                    end
                end
            end)
        end

        local function HandleMultitaskState()
            local inRaid = player:FindFirstChild("OnRaids") ~= nil
            local inTower = player:FindFirstChild("OnTowers") ~= nil

            if inRaid or inTower then
                if not NebuState.AutoFarmActive then 
                    NebuState.AutoFarmActive = true 
                    NebuState.MainWindow:Notify({Title="🔄 Multitask", Content="Entered Gamemode — Auto Farm engaged!", Type="info"})
                end
            else
                if not NebuState.AutoFarmActive then 
                    NebuState.AutoFarmActive = true 
                    NebuState.MainWindow:Notify({Title="🔄 Multitask", Content="Returned to World — Resuming world farming!", Type="success"})
                end
            end
        end

        NebuState.MainWindow:Track(player.ChildAdded:Connect(function(child)
            if child.Name == "OnRaids" or child.Name == "OnTowers" then
                HandleMultitaskState()
            end
        end))

        NebuState.MainWindow:Track(player.ChildRemoved:Connect(function(child)
            if child.Name == "OnRaids" or child.Name == "OnTowers" then
                task.wait(1)
                TeleportToLobby()
                task.delay(0.5, HandleMultitaskState) 
            end
        end))

        -- Event-driven match complete monitor for Auto-Leave
        pcall(function()
            local pgui = player:FindFirstChild("PlayerGui")
            if pgui then
                local matchesUI = pgui:WaitForChild("Matches", 5)
                if matchesUI then
                    NebuState.MainWindow:Track(matchesUI:GetPropertyChangedSignal("Enabled"):Connect(function()
                        if matchesUI.Enabled then
                            local resultFrame = matchesUI:FindFirstChild("Results") or matchesUI:FindFirstChild("Victory") or matchesUI:FindFirstChild("Defeat")
                            if resultFrame and resultFrame.Visible then
                                local btnList = resultFrame:FindFirstChild("Buttons") or resultFrame
                                local leaveBtn = btnList:FindFirstChild("Leave") or btnList:FindFirstChild("Next") or btnList:FindFirstChild("Home") or btnList:FindFirstChild("Replay")
                                
                                if leaveBtn and typeof(leaveBtn) == "Instance" and leaveBtn:IsA("GuiButton") then
                                    firesignal(leaveBtn.MouseButton1Click)
                                    firesignal(leaveBtn.Activated)
                                    
                                    -- Backup: Packets
                                    local Packets = require(game:GetService("ReplicatedStorage").Modules.Packets.Managements)
                                    local leavePacket = Packets:GetPacket("Matches", "Leave") or Packets:GetPacket("Raids", "Leave")
                                    if leavePacket and leavePacket.send then leavePacket.send() end

                                    -- Teleport to Lobby
                                    task.wait(1)
                                    pcall(function()
                                        local tpPacket = Packets:GetPacket("Teleporters", "Loaders")
                                        if tpPacket and tpPacket.send then tpPacket.send("Lobby") end
                                        
                                        -- ByteNet Teleport
                                        pcall(function()
                                            if buffer and buffer.fromstring then
                                                local args = { buffer.fromstring("\005\005\000Lobby\004\005\000Lobby") }
                                                game:GetService("ReplicatedStorage"):WaitForChild("ByteNetReliable"):FireServer(unpack(args))
                                            end
                                        end)

                                        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                        if root then
                                            local lobbyArea = workspace:FindFirstChild("Maps") and workspace.Maps:FindFirstChild("Lobby")
                                            if lobbyArea then
                                                local spawnPart = lobbyArea:FindFirstChild("SpawnLocation") or lobbyArea:FindFirstChildWhichIsA("SpawnLocation")
                                                if spawnPart then
                                                    root.CFrame = spawnPart.CFrame * CFrame.new(0, 5, 0)
                                                end
                                            end
                                        end
                                    end)
                                end
                            end
                        end
                    end))
                end
            end
        end)
        -- SETTINGS 
        local SettingsTab = NebuState.MainWindow:MakeTab({Name = "Settings", Icon = "⚙️"})
        local SuperVisSec = SettingsTab:MakeSection({Name = "🖥️ Aesthetics, UI & Hacks"})

        SuperVisSec:AddToggle({Name = "🛌 Anti-AFK", Default = false, Callback = function(s)
            if s then
                NebuState.AfkConn = player.Idled:Connect(function()
                    local vu = game:GetService("VirtualUser")
                    vu:CaptureController()
                    vu:ClickButton2(Vector2.new())
                end)
            else
                if NebuState.AfkConn then 
                    NebuState.AfkConn:Disconnect()
                    NebuState.AfkConn = nil 
                end
            end
        end})

        SuperVisSec:AddToggle({Name = "👻 Noclip", Default = false, Callback = function(s) 
            NebuState.Noclip = s
            if s and not NebuState.NoclipLoopConn then
                NebuState.NoclipLoopConn = RunService.Stepped:Connect(function()
                    if not NebuState.Noclip then 
                        NebuState.NoclipLoopConn:Disconnect()
                        NebuState.NoclipLoopConn = nil 
                        return 
                    end
                    if player.Character then
                        for _, v in ipairs(player.Character:GetDescendants()) do
                            if v:IsA("BasePart") and v.CanCollide then v.CanCollide = false end
                        end
                    end
                end)
            end
        end})

        SuperVisSec:AddToggle({Name = "🚫 Disable Visual Effects (VFX)", Default = false, Callback = function(s)
            pcall(function()
                local playerData = ReplicatedStorage:FindFirstChild("Players_Data") and ReplicatedStorage.Players_Data:FindFirstChild(player.Name)
                if playerData then
                    local settingsFolder = playerData:FindFirstChild("Settings")
                    if settingsFolder then
                        local abilityVFX = settingsFolder:FindFirstChild("Ability VFX")
                        if abilityVFX then
                            abilityVFX.Value = not s
                            NebuState.MainWindow:Notify({Title="VFX", Content=s and "Visual effects are now DISABLED locally! (Boosts FPS)" or "Visual effects are ENABLED.", Type=s and "success" or "warning"})
                        end
                    end
                end
            end)
        end})

        SuperVisSec:AddToggle({Name = "👻 Hide Player Cosmetics", Default = false, Callback = function(s)
            pcall(function()
                local playerData = ReplicatedStorage:FindFirstChild("Players_Data") and ReplicatedStorage.Players_Data:FindFirstChild(player.Name)
                if playerData then
                    local settingsFolder = playerData:FindFirstChild("Settings")
                    if settingsFolder then
                        local hideCosmetics = settingsFolder:FindFirstChild("Hide Cosmetics")
                        if hideCosmetics then
                            hideCosmetics.Value = s
                            NebuState.MainWindow:Notify({Title="Cosmetics", Content=s and "All Player Cosmetics HIDDEN! (Boosts FPS)" or "Player Cosmetics VISIBLE.", Type=s and "success" or "warning"})
                        end
                    end
                end
            end)
        end})

        SuperVisSec:AddToggle({Name = "🌙 Dark Mode", Default = true, Callback = function(s)
            pcall(function()
                if s then
                    Lighting.Brightness = 0.5
                    Lighting.GlobalShadows = false
                    Lighting.ClockTime = 0
                else
                    Lighting.Brightness = 2
                    Lighting.GlobalShadows = true
                    Lighting.ClockTime = 12
                end
            end)
        end})

        SuperVisSec:AddToggle({Name = "🔕 Mute Notifications", Default = false, Callback = function(s)
            NebuState.MainWindow._hideNotifications = s
        end})

        SuperVisSec:AddButton({Name = "FPS Boost", Icon = "🌩️", Callback = function()
            task.spawn(function() pcall(function()
                local terrain = workspace:WaitForChild("Terrain", 5)
                terrain.WaterWaveSize = 0; terrain.WaterWaveSpeed = 0; terrain.WaterReflectance = 0; terrain.WaterTransparency = 0
                Lighting.GlobalShadows = false; Lighting.FogEnd = 9e9; Lighting.Brightness = 0
                for _, c in ipairs(Lighting:GetChildren()) do 
                    if c:IsA("PostEffect") or c:IsA("Atmosphere") or c:IsA("Sky") then c:Destroy() end 
                end
                for _, descendant in ipairs(workspace:GetDescendants()) do
                    if descendant:IsA("BasePart") then descendant.Material = Enum.Material.Plastic; descendant.Reflectance = 0; descendant.CastShadow = false
                    elseif descendant:IsA("Decal") or descendant:IsA("Texture") then descendant.Transparency = 1
                    elseif descendant:IsA("ParticleEmitter") or descendant:IsA("Trail") then descendant.Lifetime = NumberRange.new(0, 0)
                    end
                end
                settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            end); NebuState.MainWindow:Notify({Title="Settings", Content="FPS Boost Enabled!", Type="info"}) end)
        end})

        SuperVisSec:AddButton({Name = "Unlock FPS", Icon = "💥", Callback = function()
            if setfpscap then
                setfpscap(999); NebuState.MainWindow:Notify({Title="FPS", Content="FPS Cap removed!", Type="success"})
            else
                NebuState.MainWindow:Notify({Title="Error", Content="Executor does not support setfpscap", Type="error"})
            end
        end})

        SuperVisSec:AddButton({Name = "Kill UI", Icon = "⛔", Danger = true, Callback = function()
            NebuState.MainWindow:Destroy()
            NebuState.Nebublox_Running = false
        end})

        local SetSec = SettingsTab:MakeSection({Name = "📁 Configuration Management"})
        local FolderName = "Nebublox"
        local ConfigsFolder = FolderName .. "/Configs"
        pcall(function() if not isfolder(FolderName) then makefolder(FolderName) end; if not isfolder(ConfigsFolder) then makefolder(ConfigsFolder) end end)

        local ConfName = ""
        local function GetConfigs() 
            local files = {"None"} 
            pcall(function() 
                for _, f in ipairs(listfiles(ConfigsFolder)) do 
                    if f:match("%.json$") then table.insert(files, f:match("([^/\\\\]+)%.json$")) end 
                end 
            end) 
            return files 
        end

        local confRow1 = SetSec:AddRow({Columns = 2, Widths = {0.8, 0.2}})
        local ConfDrop = confRow1[1]:AddDropdown({Name = "📂 Saved Profiles", Options = GetConfigs(), Default = "None", Callback = function(v) if v ~= "None" then ConfName = v end end})
        confRow1[2]:AddButton({Name = "🔄", Primary = true, Center = true, Callback = function()
            local files = GetConfigs()
            if ConfDrop and ConfDrop.Refresh then ConfDrop:Refresh(files, files[1]) end
        end})

        SetSec:AddDivider()
        SetSec:AddTextbox({Name = "✏️ Profile Name", Placeholder = "Enter config name...", Callback = function(t) ConfName = t end})
        SetSec:AddDivider()

        local confRow2 = SetSec:AddRow({Columns = 3, Widths = {0.33, 0.33, 0.33}})
        confRow2[1]:AddButton({Name = "💾 Save", Primary = true, Center = true, Callback = function() 
            if ConfName ~= "" and ConfName ~= "None" then 
                pcall(function() writefile(ConfigsFolder.."/"..ConfName..".json", HttpService:JSONEncode(NebuState or {})) end)
                NebuState.MainWindow:Notify({Title="Config",Content="Saved: "..ConfName,Type="success"}) 
            end 
        end})
        confRow2[2]:AddButton({Name = "📂 Load", Center = true, Callback = function() 
            if ConfName ~= "" and ConfName ~= "None" then 
                pcall(function() local p = ConfigsFolder.."/"..ConfName..".json"; if isfile(p) then for k,v in pairs(HttpService:JSONDecode(readfile(p))) do NebuState[k] = v end end end)
                NebuState.MainWindow:Notify({Title="Config",Content="Loaded: "..ConfName,Type="success"}) 
            end 
        end})
        confRow2[3]:AddButton({Name = "🗑️ Delete", Danger = true, Center = true, Callback = function() 
            if ConfName ~= "" and ConfName ~= "None" then 
                pcall(function() delfile(ConfigsFolder.."/"..ConfName..".json") end)
                NebuState.MainWindow:Notify({Title="Config",Content="Deleted: "..ConfName,Type="error"}) 
            end 
        end})

        SetSec:AddButton({Name = "🔄 Reset to Defaults", Danger = true, Callback = function()
            local defaults = {
                AutoAttack = false,
                AutoCollect = false,
                FastAutoClick = false,
                Noclip = false,
                AutoSkipAnimations = false
            }
            for k, v in pairs(defaults) do NebuState[k] = v end
            NebuState.MainWindow:Notify({Title="Settings", Content="Reset to system defaults.", Type="warning"})
        end})
    end
end

