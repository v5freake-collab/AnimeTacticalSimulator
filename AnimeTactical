        end

        local function GetTarget()
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then return nil end
            local best, dist = nil, 1000
            
            local targetFolders = {}
            local worlds = workspace:FindFirstChild("Worlds")
            if worlds and worlds:FindFirstChild("Targets") then
                if worlds.Targets:FindFirstChild("Server") then table.insert(targetFolders, worlds.Targets.Server) end
                if worlds.Targets:FindFirstChild("Clients") then table.insert(targetFolders, worlds.Targets.Clients) end
            else
                table.insert(targetFolders, workspace) 
            end

            for _, folder in ipairs(targetFolders) do
                local list = (folder == workspace) and folder:GetChildren() or folder:GetDescendants()
                for _, mob in ipairs(list) do
                    if mob:IsA("Model") and mob ~= char and IsAlive(mob) then
                        local isNPC = workspace:FindFirstChild("NPCs") and mob:IsDescendantOf(workspace.NPCs)
                        local isPlayerUnit = mob:GetFullName():find("Units") or game.Players:GetPlayerFromCharacter(mob)
                        if not isNPC and not isPlayerUnit then
                            local rName = GetRealEnemyName(mob)
                            if table.find(NebuState.SelectedEnemy, "All") or table.find(NebuState.SelectedEnemy, rName) then
                                local mRoot = mob:FindFirstChild("HumanoidRootPart") or mob.PrimaryPart
                                if mRoot then
                                    local d = (root.Position - mRoot.Position).Magnitude
                                    if d < dist then best, dist = mob, d end
                                end
                            end
                        end
                    end
                end
            end
            return best
        end

