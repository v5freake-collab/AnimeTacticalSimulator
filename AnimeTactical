-- Helper function to safely destroy UI elements
local function safeDestroy(instance)
    if instance and instance.Destroy then
        pcall(function() instance:Destroy() end)
    end
end

-- NEBUBLOX CLOSE UI (hotkey: RightShift + K)
do
    local function stopNebustates()
        local genvTable = getgenv and getgenv() or shared
        for k, v in pairs(genvTable) do
            if type(k) == "string" and type(v) == "table" and k:lower():find("nebustate") then
                v.Nebublox_Running = false
                v.AutoAttack = false
                v.AutoCollect = false
                v.FastAutoClick = false
                v.AutoSkipAnimations = false
            end
        end
    end

    local function closeNebubloxUI()
        stopNebustates()

        pcall(function()
            for _, v in ipairs(Lighting:GetChildren()) do
                if v:IsA("BlurEffect") and (v.Name == "NebubloxBlur" or v.Name:lower():find("nebublox")) then
                    v:Destroy()
                end
            end
        end)

        local function scanAndClose(parent)
            for _, inst in ipairs(parent:GetChildren()) do
                if inst:IsA("ScreenGui") then
                    local n = (inst.Name or ""):lower()
                    if n:find("nebublox") or n:find("animetactical") or n:find("tactical") then
                        safeDestroy(inst)
                    end
                end
            end
        end

        scanAndClose(CoreGui)
        scanAndClose(player:WaitForChild("PlayerGui"))
    end

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if UserInputService:IsKeyDown(Enum.KeyCode.RightShift) and input.KeyCode == Enum.KeyCode.K then
            closeNebubloxUI()
        end
    end)
end

