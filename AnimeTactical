    local Signal = {}
    Signal.__index = Signal
    function Signal.new()
        local self = setmetatable({}, Signal)
        self._bindable = Instance.new("BindableEvent")
        return self
    end
    function Signal:Connect(fn) return self._bindable.Event:Connect(fn) end
    function Signal:Fire(...) self._bindable:Fire(...) end
    function Signal:Destroy() self._bindable:Destroy() end

    local InventoryBus = {}
    InventoryBus.__index = InventoryBus
    function InventoryBus.new()
        return setmetatable({ Inventory = nil, LastSync = 0, Changed = Signal.new() }, InventoryBus)
    end
    function InventoryBus:Set(inv, source)
        if type(inv) ~= "table" then return false end
        self.Inventory = inv
        self.LastSync = os.clock()
        self.Changed:Fire(inv, source)
        return true
    end

    local InventoryController = {}
    InventoryController.__index = InventoryController
    function InventoryController.new()
        return setmetatable({ Bus = InventoryBus.new(), Running = false }, InventoryController)
    end
